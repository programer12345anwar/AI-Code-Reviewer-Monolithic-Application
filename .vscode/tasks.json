{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "backend: prepare classpath",
      "type": "shell",
      "command": ".\\mvnw.cmd",
      "args": [
        "-q",
        "dependency:copy-dependencies",
        "compile"
      ],
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "problemMatcher": "$javac",
      "group": "build"
    }
  ]
}
