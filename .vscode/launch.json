{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "java",
      "name": "Run Backend (Spring Boot)",
      "request": "launch",
      "mainClass": "com.anwar.aicodereview.AicodereviewApplication",
      "cwd": "${workspaceFolder}/backend",
      "console": "integratedTerminal",
      "preLaunchTask": "backend: prepare classpath",
      "classPaths": [
        "${workspaceFolder}/backend/target/classes",
        "${workspaceFolder}/backend/target/dependency/*"
      ]
    }
  ]
}
